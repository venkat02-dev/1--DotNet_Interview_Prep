// ❌ WITHOUT Factory — Repository knows too much
public class PortfolioRepository
{
    public void CreatePortfolio(int customerId, Portfolio portfolio)
    {
        // Repository has to figure out: Which DB? MySQL or SQL Server? Which server?
        var customerConfig = LookupCustomerDatabase(customerId); // ← shouldn't be here
        string connectionString = BuildConnectionString(customerConfig); // ← shouldn't be here
        
        var dbContext = customerConfig.Engine == "MySQL" 
            ? new MySqlBatchContext(connectionString)  // ← shouldn't be here
            : new SqlServerBatchContext(connectionString); // ← shouldn't be here
        
        dbContext.Portfolios.Add(portfolio);
        dbContext.SaveChanges();
    }
}

// ✅ WITH Factory — Repository only cares about data operations
public class PortfolioRepository
{
    private readonly IBatchContextFactory _batchContextFactory;

    public void CreatePortfolio(int customerId, Portfolio portfolio)
    {
        using (var dbContext = _batchContextFactory.Create(customerId)) // ← one call, done
        {
            dbContext.Portfolios.Add(portfolio);
            dbContext.SaveChanges();
        }
    }
}


// ✅The Interface (contract)
// Src/LN.Core.Domain/Interfaces/DataAccess/Factories/IBatchContextFactory.cs
public interface IBatchContextFactory
{
    IBatchContext Create(int customerId);                          // Write → primary DB
    IBatchContext Create(int customerId, DbConnectionType type);  // Explicit control
    IBatchContext CreateReadOnlyContext(int customerId);           // Read → replica DB
}


// ✅The Factory (decision maker)
// Src/LN.Core.DataAccess/Factories/BatchContextFactory.cs
public class BatchContextFactory : IBatchContextFactory
{
    public IBatchContext Create(int customerId)
    {
        if (customerId == 0)
            return new BatchContext();  // Default system DB
        else
            return new BatchContext(customerId, DbConnectionType.Live);  // Customer-specific
    }

    public IBatchContext CreateReadOnlyContext(int customerId)
    {
        return new BatchContext(customerId, DbConnectionType.ReadOnly);  // Read replica
    }
}


// ✅The Product (DbContext with dynamic connection)
// Src/LN.Core.DataAccess/Contexts/BatchContext.cs
public class BatchContext : DbContext, IBatchContext
{
    // Default — system database
    public BatchContext() : base("name=System") 
    {
        ConfigureContext();
    }

    // Customer-specific — resolves DB at runtime
    public BatchContext(int customerId, DbConnectionType connectionType) 
        : this(CoreContext.GetCustomerDbIdentifier(customerId, connectionType)) 
    { }

    // The actual resolution — MySQL or SQL Server, which server, which DB
    private BatchContext(IDbIdentifier dbId, DbConnectionType connectionType) 
        : base(connectionType == DbConnectionType.ReadOnly 
            ? dbId.GetReportingReadOnlyDatabaseIdentifier("name=System_Report_ReadOnly")
            : dbId.GetDatabaseIdentifier("name=System"))
    {
        ConfigureContext();
    }

    private void ConfigureContext()
    {
        Database.SetInitializer<BatchContext>(null);
        Configuration.AutoDetectChangesEnabled = false;  // Performance: bulk operations
        Configuration.LazyLoadingEnabled = true;
        Configuration.ProxyCreationEnabled = false;
    }

    // DbSets
    public DbSet<Portfolio> Portfolios { get; set; }
    public DbSet<PortfolioDivision> PortfolioDivisions { get; set; }
    public DbSet<PortfolioEmailAddress> PortfolioEmailAddresses { get; set; }
}
